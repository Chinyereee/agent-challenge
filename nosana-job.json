{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "cli",
    "description": "ORACLE — On-chain Research & Analysis Cognitive Layer Engine on Nosana GPU network"
  },
  "ops": [
    {
      "type": "container/run",
      "id": "oracle-agent",
      "args": {
        "image": "chinyereee/oracle-agent:latest",
        "gpu": false,
        "expose": 3000,
        "cmd": ["node", "dist/index.js"],
        "env": {
          "OPENROUTER_API_KEY": "YOUR_OPENROUTER_API_KEY",
          "SERVER_PORT": "3000",
          "LOG_LEVEL": "info",
          "NODE_ENV": "production",
          "DATABASE_URL": "sqlite:./data/oracle.sqlite"
        },
        "resources": {
          "cpu": 2000,
          "memory": 4096
        }
      }
    }
  ]
}
