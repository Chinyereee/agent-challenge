{
  "name": "oracle-agent",
  "version": "0.1.0",
  "private": true,
  "description": "ORACLE — On-chain Research & Analysis Cognitive Layer Engine. Powered by ElizaOS v1 + Nosana's decentralised GPU network.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "build:start": "tsc && node dist/index.js",
    "docker:build": "docker build -t chinyereee/oracle-agent:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env chinyereee/oracle-agent:latest"
  },
  "dependencies": {
    "@elizaos/core": "^1.0.0",
    "@elizaos/plugin-bootstrap": "^1.0.0",
    "@elizaos/plugin-openrouter": "^1.0.0",
    "@elizaos/plugin-telegram": "^1.0.0",
    "@elizaos/server": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=23.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "elizaos",
    "agent",
    "solana",
    "defi",
    "nosana",
    "ai",
    "web3"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0"
}
