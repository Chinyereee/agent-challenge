# Git
.git
.gitignore

# Node
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files — keep .env.example (it's a safe template), exclude secrets
.env
.env.local
.env.*.local
.env.*
!.env.example

# Build output
.mastra/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Documentation
*.md
LICENSE

# Docker
Dockerfile
.dockerignore

# Runtime data — generated at startup, should not be in image
data/
*.log

# Temporary files
*.tmp
*.temp
.cache/

# Test files
coverage/
.nyc_output/
*.test.js
*.spec.js
